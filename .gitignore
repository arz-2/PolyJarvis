# ── Claude Code (machine-specific, use .mcp.json.example as template) ─────────
.mcp.json
.claude/settings.local.json

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
.python-version

# ── Runtime state (not source) ────────────────────────────────────────────────
mcp-lammps-engine/run_state.json
mcp-radonpy-server/src/timer.dat

# ── Simulation data and experiment database (local only) ──────────────────────
# Calibration benchmark cells (data/CALIB_*) are local throwaways — kept for
# re-calibration / directional_probe provenance, never committed (covered by data/*).
data/*
!data/TEMPLATE/
db/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Simulation outputs (large, not source) ────────────────────────────────────
*.dump
*.data
*.restart
*.xtc
*.dcd
*.log

# ── Manuscript & private notes (not for public repo) ──────────────────────────
revision.md
literature/
guides/TODO_OWNER.md
guides/ROADMAP.md
guides/REVISION_PARAMS.md
data/Polymer_Handbook/
