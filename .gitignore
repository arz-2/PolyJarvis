# ── Claude Code (machine-specific, use .mcp.json.example as template) ─────────
.mcp.json
.claude/settings.local.json

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
.python-version
.pytest_cache/
.venv/

# ── Runtime state (not source) ────────────────────────────────────────────────
mcp-lammps-engine/run_state.json
timer.dat
# generated by `python -m tools.runlog_miner --playbook`; consulted locally by /recover
guides/RECOVERY_PLAYBOOK.md

# ── Simulation data and experiment database (local only) ──────────────────────
# Calibration cells (data/CALIB_<FAM>/) ship the small emc_build.{data,params} per FF so a
# fresh clone can host-match engine defaults via /calibrate-hardware without an EMC build.
# Only those two files per cell are committed; every other artifact in the dir stays local.
data/*
!data/TEMPLATE/
!data/CALIB_*/
data/CALIB_*/*
db/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Simulation outputs (large, not source) ────────────────────────────────────
*.dump
*.data
*.restart
*.xtc
*.dcd
*.log

# ── Manuscript & internal planning docs (not for public repo) ─
revision.md
literature/
# manuscript/ stays local EXCEPT the published subset below: benchmark provenance (data/),
# analysis data (csv/), figure/table generators, the two manuscript figures, the recovery
# benchmark, and the release rebuilder. New files under manuscript/data/ are ignored like the
# old data/* — collect_data.sh stages the provenance subset with `git add -f`.
manuscript/*
!manuscript/csv/
!manuscript/recovery/
!manuscript/collect_data.sh
!manuscript/figures/
manuscript/figures/*
!manuscript/figures/figure1_architecture.png
!manuscript/figures/figure2_conversation.png
!manuscript/gen_figure3_density_parity.py
!manuscript/gen_figure4_tg_curves.py
!manuscript/gen_figure5_bulk_modulus.py
!manuscript/gen_figure6_rdf.py
!manuscript/gen_table_bulk_modulus_robustness.py
!manuscript/gen_table_compute_cost.py
!manuscript/gen_table_structure_diagnostics.py
!manuscript/plot_rdf.py
!manuscript/replot_from_tool.py
docs/LLM_CONTRIBUTION_PLAN.md
docs/UI_PLAN.md
guides/TODO_OWNER.md
guides/ROADMAP.md
guides/REVISION_PARAMS.md
data/Polymer_Handbook/

# ── Committed calibration-cell payload (must come last to win over *.data/*.log above) ──
# Only emc_build.{data,params} per CALIB_<FAM> cell are tracked; see /calibrate-hardware.
!data/CALIB_*/emc_build.data
!data/CALIB_*/emc_build.params
