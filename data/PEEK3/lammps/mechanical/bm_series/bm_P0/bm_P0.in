# ============================================================
# PolyJarvis LAMMPS Engine - NPT Simulation Template
# ============================================================
# Stage: NPT (constant pressure, constant temperature)
# Use cases:
#   - Density equilibration after heating
#   - Compression/decompression sweeps
#   - Production run for density, Cp, modulus
#   - Single temperature point in Tg sweep
#
# NOTE: For CPU runs with restarts (safe default for equilibration).
#       GPU+NPT+restart causes volume-change memory reallocation crashes.
#       Use GPU flag only when restart is disabled (short production runs).
#
# Tunable parameters (injected by script_generator.py):
#   DATA_FILE        - .data or .restart file to read
#   READ_COMMAND     - "read_data" or "read_restart"
#   LOG_FILE         - log filename
#   LOG_APPEND       - "append" or ""
#   DUMP_FILE        - trajectory filename
#   LAST_DUMP_FILE   - final snapshot filename
#   WRITE_DATA_FILE  - output .data filename
#   RESTART_FILE_1/2 - restart checkpoint filenames
#   RESTART_FREQ     - steps between restart writes
#   RESTART_BLOCK    - full restart command or empty
#   PAIR_STYLE_BLOCK - pair + kspace style lines
#   BOND_STYLE, ANGLE_STYLE, DIHEDRAL_STYLE, IMPROPER_STYLE
#   GPU_PACKAGE      - "package gpu 1 neigh no" or empty
#   T_START          - initial temperature (K)
#   T_FINAL          - final temperature (K)
#   T_DAMP           - thermostat damping (fs), recommended 100*timestep
#   P_START          - initial pressure (atm)
#   P_FINAL          - final pressure (atm)
#   P_DAMP           - barostat damping (fs), recommended 1000*timestep
#   TIMESTEP         - integration timestep (fs)
#   N_STEPS          - number of MD steps
#   THERMO_FREQ      - thermo output frequency
#   DUMP_FREQ        - dump output frequency
#   SHAKE_BLOCK      - "fix shake..." or empty
#   UNSHAKE_BLOCK    - "unfix shake..." or empty
#   INIT_VELOCITY_BLOCK - "velocity all create..." or empty
# ============================================================

log /home/arz2/PolyJarvis/data/PEEK3/lammps/mechanical/bm_series/bm_P0/bm_P0.log 
units real
atom_style full
boundary p p p

# --- Force Field Styles ---
pair_style lj/class2/coul/long 9.5 9.5
kspace_style pppm 1e-6
dielectric 1.000000
bond_style class2
angle_style class2
dihedral_style class2
improper_style class2
special_bonds lj/coul 0 0 1
pair_modify mix sixthpower tail yes
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes
neigh_modify one 4000
# KOKKOS: package loaded via -pk kokkos on the command line

read_data /home/arz2/PolyJarvis/data/PEEK3/lammps/npt_prod300/npt_prod300_out.data


# --- Thermo Output ---
thermo_style custom step time temp press enthalpy etotal ke pe ebond eangle edihed eimp evdwl ecoul elong etail vol lx ly lz density pxx pyy pzz
thermo_modify flush yes
thermo 100

# --- Trajectory ---
dump dump_npt all custom 1000 /home/arz2/PolyJarvis/data/PEEK3/lammps/mechanical/bm_series/bm_P0/bm_P0.dump id type mol x y z ix iy iz vx vy vz

# --- Restart Checkpointing ---
restart 10000 npt_1.rst npt_2.rst

# --- Initial Velocities (optional) ---
# Velocities read from data file

# --- SHAKE Constraints ---
fix shake_fix all shake 1e-4 1000 0 m 1.008

# --- NPT Thermostat + Barostat (Nose-Hoover) ---
# T_damp = 100.0 fs  (heat bath coupling)
# P_damp = 1000.0 fs  (pressure bath coupling, ~10x T_damp typical)
# Ramp: T=300.0->300.0K  P=0.0->0.0atm
timestep 1.0
fix npt_fix all npt temp 300.0 300.0 100.0 iso 0.0 0.0 1000.0

run 500000

# --- Cleanup ---
unfix npt_fix
unfix shake_fix
undump dump_npt

# --- Write Output ---
write_dump all custom /home/arz2/PolyJarvis/data/PEEK3/lammps/mechanical/bm_series/bm_P0/bm_P0_last.dump id type mol x y z xu yu zu vx vy vz modify sort id
write_data /home/arz2/PolyJarvis/data/PEEK3/lammps/mechanical/bm_series/bm_P0/bm_P0_out.data

print "STAGE COMPLETE: NPT T=300.0->300.0K P=0.0->0.0atm steps=500000"
quit
