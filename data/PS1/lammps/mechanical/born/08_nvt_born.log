# --- Thermo Output ---
# pxx pyy pzz are required for Var(P) in the Born bulk modulus analysis
thermo_style custom step time temp press enthalpy etotal ke pe ebond eangle edihed eimp evdwl ecoul elong etail vol lx ly lz density pxx pyy pzz
thermo_modify flush yes
thermo 1000

# --- Trajectory ---
dump dump_nvt_born all custom 5000 08_nvt_born.dump id type mol x y z ix iy iz vx vy vz

# --- Restart Checkpointing ---
restart 50000 08_nvt_born_1.rst 08_nvt_born_2.rst

# --- Initial Velocities (optional) ---
# Velocities read from data file

# --- SHAKE Constraints ---
fix shake_fix all shake 1e-4 1000 0 m 1.008
Finding SHAKE clusters ...
    2390 = # of size 2 clusters
     400 = # of size 3 clusters
      10 = # of size 4 clusters
       0 = # of frozen angles
  find clusters CPU = 0.001 seconds

# --- NVT Thermostat (Nose-Hoover) ---
timestep 1
fix nvt_fix all nvt temp 300 300 100

# --- Born Matrix (EXTRA-COMPUTE package required) ---
# compute born/matrix numdiff syntax: numdiff delta virial_compute_ID
# delta = finite-difference strain displacement; virial_compute_ID = named pressure compute.
# Output vector (21 elements, Voigt notation, units: atm):
#   [1]=C11, [2]=C22, [3]=C33, [4]=C44, [5]=C55, [6]=C66,
#   [7]=C12, [8]=C13, ..., [12]=C23, ...
# K_Born = (C11+C22+C33 + 2*C12 + 2*C13 + 2*C23) / 9
compute born_press all pressure thermo_temp
compute born_matrix all born/matrix numdiff 0.0001 born_press
variable b11 equal c_born_matrix[1]
variable b22 equal c_born_matrix[2]
variable b33 equal c_born_matrix[3]
variable b12 equal c_born_matrix[7]
variable b13 equal c_born_matrix[8]
variable b23 equal c_born_matrix[12]
# Average Born elements every BORN_FREQ steps using BORN_REPEAT samples taken BORN_EVERY steps apart.
# Bulk modulus Born term: K_Born = (b11+b22+b33 + 2*b12+2*b13+2*b23) / 9
fix born_avg all ave/time 10 100 1000 v_b11 v_b22 v_b33 v_b12 v_b13 v_b23 file /home/alexzhao/PolyJarvis/data/PS1/lammps/mechanical/born/born_matrix.dat

