dump dump_npt all custom 1000 npt_prod300.dump id type mol x y z ix iy iz vx vy vz

# --- Restart Checkpointing ---
# No restart checkpointing

# --- Initial Velocities (optional) ---
# Velocities read from data file

# --- SHAKE Constraints ---
# SHAKE disabled

# --- NPT Thermostat + Barostat (Nose-Hoover) ---
# T_damp = 100.0 fs  (heat bath coupling)
# P_damp = 1000.0 fs  (pressure bath coupling, ~10x T_damp typical)
# Ramp: T=300.0->300.0K  P=1.0->1.0atm
timestep 1.0
fix npt_fix all npt temp 300.0 300.0 100.0 iso 1.0 1.0 1000.0

run 2000000

