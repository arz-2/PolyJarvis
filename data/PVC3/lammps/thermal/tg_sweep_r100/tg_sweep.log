# --- Velocity initialization at T_START (once only — Rule A) ---
velocity all create 550.0 730559 mom yes rot yes dist gaussian

# --- Temperature staircase (inherits momenta across steps — Rule A) ---
variable temps index 550 530 510 490 470 450 430 410 390 370 350 330 310 290 270 250 230 210 190 170 150
label TEMP_LOOP
  timestep 1
  fix npt_tg all npt temp ${temps} ${temps} 100 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 550 ${temps} 100 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 550 550 100 iso 1.0 1.0 1000.0
  run 200000
