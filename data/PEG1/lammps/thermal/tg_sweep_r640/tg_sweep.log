thermo_modify flush yes
thermo 500

# --- Velocity initialization at T_START (once only — Rule A) ---
velocity all create 440.0 21416 mom yes rot yes dist gaussian

# --- Temperature staircase (inherits momenta across steps — Rule A) ---
variable temps index 440 420 400 380 360 340 320 300 280 260 240 220 200 180 160 140 120 100
label TEMP_LOOP
  timestep 1.0
  fix npt_tg all npt temp ${temps} ${temps} 100 iso 1.0 1.0 1000
  fix npt_tg all npt temp 440 ${temps} 100 iso 1.0 1.0 1000
  fix npt_tg all npt temp 440 440 100 iso 1.0 1.0 1000
  run 31250

