log bm_P1000.log
units real
atom_style full
boundary p p p
pair_style lj/cut 14.0
dielectric 1.000000
bond_style harmonic
angle_style harmonic
dihedral_style multi/harmonic
improper_style none
special_bonds lj 0 0 0
pair_modify mix arithmetic tail yes
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes
neigh_modify one 4000
read_data /home/arz2/PolyJarvis/data/cis-PBD1/lammps/equil/npt_production/npt_production_out.data
include /home/arz2/PolyJarvis/data/cis-PBD1/lammps/equil/emc_build.params
thermo_style custom step time temp press enthalpy etotal ke pe evdwl etail vol lx ly lz density pxx pyy pzz
thermo_modify flush yes
thermo 1000
timestep 2.0
fix npt_fix all npt temp 300.0 300.0 100.0 iso 1000.0 1000.0 1000.0
run 500000
unfix npt_fix
write_data bm_P1000_out.data
print "BM STAGE COMPLETE: P=1000 atm"
quit
