thermo 500

# --- Velocity initialization at T_START (once only — Rule A) ---
velocity all create 450.0 22230 mom yes rot yes dist gaussian

# --- Temperature staircase (inherits momenta across steps — Rule A) ---
variable temps index 450 430 410 390 370 350 330 310 290 270 250 230 210 190 170 150 130 110 100
label TEMP_LOOP
  timestep 2.0
  fix npt_tg all npt temp ${temps} ${temps} 100.0 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 450 ${temps} 100.0 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 450 450 100.0 iso 1.0 1.0 1000.0
  run 250000

