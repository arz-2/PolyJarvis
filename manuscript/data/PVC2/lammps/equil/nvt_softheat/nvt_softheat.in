# ============================================================
# PolyJarvis LAMMPS Engine - NVT Simulation Template
# ============================================================
# Stage: NVT (constant volume, constant temperature)
# Use cases:
#   - Initial heating to melt temperature
#   - Constant-T annealing step
#   - Production run at fixed density (after NPT equilibration)
#   - Temperature ramp up or down
#
# Tunable parameters (injected by script_generator.py):
#   DATA_FILE        - .data or .restart file to read
#   READ_COMMAND     - "read_data" or "read_restart"
#   LOG_FILE         - log filename
#   LOG_APPEND       - "append" or "" (overwrite)
#   DUMP_FILE        - trajectory filename
#   LAST_DUMP_FILE   - final snapshot filename
#   WRITE_DATA_FILE  - output .data filename
#   RESTART_FILE_1   - restart checkpoint file 1
#   RESTART_FILE_2   - restart checkpoint file 2
#   RESTART_FREQ     - steps between restart writes
#   RESTART_BLOCK    - full restart command or empty
#   PAIR_STYLE_BLOCK - pair + kspace style lines
#   BOND_STYLE, ANGLE_STYLE, DIHEDRAL_STYLE, IMPROPER_STYLE
#   GPU_PACKAGE      - "package gpu 1 neigh no" or empty
#   T_START          - initial temperature (K)
#   T_FINAL          - final temperature (K) -- ramp or constant
#   T_DAMP           - thermostat damping (fs), recommended 100*timestep
#   TIMESTEP         - integration timestep (fs), typically 1.0
#   N_STEPS          - number of MD steps
#   THERMO_FREQ      - thermo output frequency (steps)
#   DUMP_FREQ        - dump output frequency (steps)
#   SHAKE_BLOCK      - "fix shake..." or empty
#   UNSHAKE_BLOCK    - "unfix shake..." or empty
#   INIT_VELOCITY_BLOCK - "velocity all create..." or empty
# ============================================================

log nvt_softheat.log 
units real
atom_style full
boundary p p p

# --- Force Field Styles ---
pair_style lj/class2/coul/long 9.5 9.5
kspace_style pppm 1e-6
dielectric 1.000000
bond_style class2
angle_style class2
dihedral_style class2
improper_style class2
special_bonds lj/coul 0 0 1
pair_modify mix sixthpower tail yes
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes
neigh_modify one 4000
# KOKKOS: package loaded via -pk kokkos on the command line

read_data /home/alexzhao/PolyJarvis/data/PVC2/lammps/equil/minimize/minimize_out.data
include /home/alexzhao/PolyJarvis/data/PVC2/lammps/equil/emc_build.params

# --- Thermo Output ---
thermo_style custom step time temp press enthalpy etotal ke pe ebond eangle edihed eimp evdwl ecoul elong etail vol lx ly lz density pxx pyy pzz
thermo_modify flush yes
thermo 1000

# --- Trajectory ---
dump dump_nvt all custom 1000 nvt_softheat.dump id type mol x y z ix iy iz vx vy vz

# --- Restart Checkpointing ---
restart 10000 nvt_1.rst nvt_2.rst

# --- Initial Velocities (optional) ---
velocity all create 300.0 873034 mom yes rot yes dist gaussian

# --- SHAKE Constraints ---
# Constrains H-X bonds to allow 2fs timestep
# SHAKE disabled

# --- NVT Thermostat (Nose-Hoover) ---
# T_damp = 50.0 fs  (coupling timescale for heat exchange)
# Ramp: 300.0 K -> 610.0 K over 300000 steps
timestep 0.5
fix nvt_fix all nvt temp 300.0 610.0 50.0

run 300000

# --- Cleanup ---
unfix nvt_fix

undump dump_nvt

# --- Write Output ---
write_dump all custom nvt_softheat_last.dump id type mol x y z xu yu zu vx vy vz modify sort id
write_data /home/alexzhao/PolyJarvis/data/PVC2/lammps/equil/nvt_softheat/nvt_softheat_out.data

print "STAGE COMPLETE: NVT T=300.0->610.0K steps=300000"
quit
