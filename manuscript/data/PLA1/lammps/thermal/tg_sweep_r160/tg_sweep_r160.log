thermo 500

# --- Velocity initialization at T_START (once only — Rule A) ---
velocity all create 600.0 324127 mom yes rot yes dist gaussian

# --- Temperature staircase (inherits momenta across steps — Rule A) ---
variable temps index 600 580 560 540 520 500 480 460 440 420 400 380 360 340 320 300 280 260 240 220
label TEMP_LOOP
  timestep 1.0
  fix npt_tg all npt temp ${temps} ${temps} 100.0 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 600 ${temps} 100.0 iso 1.0 1.0 1000.0
  fix npt_tg all npt temp 600 600 100.0 iso 1.0 1.0 1000.0
  run 125000

