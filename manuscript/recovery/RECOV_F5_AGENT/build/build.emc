(* EMC: Script *)

(* Created by emc_setup.pl v4.1.5, March 30, 2024
   on Sun Jun 28 00:18:41 EDT 2026 *)

(* define variables *)

variables	= {
  seed		-> 1001,
  ntotal	-> 3000,
  fshape	-> 1,
  output	-> "emc_build",
  field		-> "pcff/pcff",
  location1	-> $root+"field/",

  nav		-> 0.6022141179,
  temperature	-> 300,
  radius	-> 5,
  nrelax	-> 100,
  weight_nonbond -> 0.0001,
  weight_bond	-> 0.0001,
  weight_focus	-> 1,
  cutoff	-> 9.5,
  charge_cutoff	-> 9.5,
  kappa		-> 4,

  density1	-> 0.5,
  lprevious	-> 0,
  lphase	-> 0,

  f_poly	-> 2,

  chem_repeat	-> "*NC(=O)NCCCCCC*",
  chem_cap	-> "*[H]"
};

output		= {
  debug		-> false,
  exit		-> true,
  info		-> true,
  warning	-> true
};

(* define force field *)

field		= {
  id		-> pcff,
  mode		-> cff,
    name	-> {location1+field+".frc", location1+field+"_templates.dat"},
  compress	-> false
};

(* define groups *)

groups		= {
  group		-> {
    id		-> repeat, depth -> 8, chemistry -> chem_repeat,
    connects	-> {
      {source	-> $end1, destination -> {cap, $end1}},
      {source	-> $end1, destination -> {repeat, $end2}},
      {source	-> $end2, destination -> {cap, $end1}},
      {source	-> $end2, destination -> {repeat, $end1}}
    }
  },
  group		-> {
    id		-> cap, depth -> 8, chemistry -> chem_cap,
    connects	-> {
      {source	-> $end1, destination -> {repeat, $end2}},
      {source	-> $end1, destination -> {repeat, $end1}}
    }
  }
};

field		= {
  mode		-> apply,
  check		-> {
    atomistic	-> true,
    charge	-> true
  },
  debug		-> false
};

(* determine simulation sizing *)

variables	= {

  (* lengths *)

  lg_repeat	-> nsites(repeat),
  lg_cap	-> nsites(cap),
  norm_poly	-> 100,

  l_poly	-> (5*lg_repeat+2*lg_cap)*100/norm_poly,

  (* masses *)

  mg_repeat	-> mass(repeat),
  mg_cap	-> mass(cap),

  norm_poly	-> 100,

  m_poly	-> (5*mg_repeat+2*mg_cap)*100/norm_poly,


  (* sizing *)

  n_poly	-> f_poly,


  (* system sizing *)

  ntotal	-> 0,
  mtotal	-> 0
};

(* define interactions *)

simulation	= {
  units		-> {
    permittivity -> 1,
    seed	-> seed
  },
  types		-> {
    coulomb	-> {
      pair	-> {active -> true, cutoff -> charge_cutoff}
    }
  }
};

(* clusters phase 1 *)

clusters	= {
  progress	-> none,
  polymer	-> {
    id		-> poly, system -> main, type -> alternate,
    n		-> int(100*n_poly/norm_poly+0.5),
    groups	-> {repeat, cap},
    weights	-> {1, 1},
    nrepeat	-> {5, 2}
  }
};

field		= {
  mode		-> apply,
  check		-> {
    atomistic	-> true,
    charge	-> true
  },
  debug		-> false
};

(* build phase 1 *)

types		= {
  cff		-> {
    pair	-> {active -> true, mode -> repulsive}
  }
};

variables	= {
  nphase1	-> ntotal()-ntotal,
  mphase1	-> mtotal()-mtotal,
  vphase1	-> mphase1/nav/density1,
  lbox		-> (vphase1/fshape)^(1/3),
  lphase1	-> fshape*lbox,
  lxx		-> lphase1,
  lyy		-> lbox,
  lzz		-> lbox,
  lzy		-> 0,
  lzx		-> 0,
  lyx		-> 0,
  lphase	-> lphase1,
  ntotal	-> nphase1,
  mtotal	-> mphase1,
  vtotal	-> vphase1
};

build		= {
  system	-> {
    id		-> main,
    split	-> false,
    geometry	-> {xx -> lxx, yy -> lyy, zz -> lzz,
		    zy -> lzy, zx -> lzx, yx -> lyx},
    temperature	-> temperature,
    flag	-> {charge -> true, geometry -> true, map -> true, pbc -> true}
  },
  select	-> {
    progress	-> list,
    frequency	-> 1,
    name	-> "error",
    order	-> random,
    cluster	-> {poly},
    relax	-> {ncycles -> nrelax, radius -> radius},
    grow	-> {
      method	-> energetic,
      check	-> all,
      nbonded	-> 20,
      ntrials	-> 20,
      niterations -> 1000,
      theta	-> 0,
      weight	-> {
	bonded	-> weight_bond, nonbonded -> weight_nonbond,
	focus	-> weight_focus}
    }
  }
};

force		= {style -> none, message -> nkt};
force		= {style -> init, message -> nkt};

(* LAMMPS profile variables *)

variables	= {
  nl_poly	-> nclusters(clusters -> poly)
};

(* storage *)

put		= {name -> output, compress -> true};

pdb		= {name -> output, compress -> true, extend -> false,
		   forcefield -> cff, detect -> false, hexadecimal -> false,
		   unwrap -> true, pbc -> true, atom -> index, residue -> index,
		   segment -> index, rank -> false, vdw -> false, cut -> false,
		   fixed -> true, rigid -> true, connectivity -> false,
		   parameters -> false};

lammps		= {name -> output, mode -> put, forcefield -> cff,
		   parameters -> true, types -> false, unwrap -> true,
		   charges -> true, ewald -> true};
